# Variáveis de Ambiente - PROJATTO
# Crie um arquivo .env na raiz do projeto com esses valores preenchidos
# NUNCA commit o arquivo .env - ele contém dados sensíveis!

# === CREDENCIAIS DE EMAIL ===
# Use uma "Senha de App" do Gmail (não a senha da conta principal)
# Veja: https://myaccount.google.com/apppasswords
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app-aqui

# === CONFIGURAÇÃO DO SERVIDOR ===
# Porta onde o servidor Express rodará (padrão: 5500)
PORT=5500

# === CORS - Origens Permitidas ===
# URLs permitidas para fazer requisições ao backend
# Múltiplas origens podem ser separadas por vírgula
CORS_ORIGIN=http://localhost:5500

# === AMBIENTE ===
# Valores: development, production
NODE_ENV=development